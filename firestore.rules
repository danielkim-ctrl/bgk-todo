rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ 사용자 지시로 auth 없이 공개 접근 허용 상태 (2026-04-22)
    // PIN 로그인이 클라이언트 UI 보안을 담당하고, 인증 세팅은 추후 별도 진행 예정.
    // URL이 노출되면 누구나 데이터를 읽고 쓸 수 있으니 추후 auth 세팅 필수.

    // ── 팀 전체 공유 todo 데이터 (단일 문서 경로) ───────────────────────────
    match /todos_db/{document} {
      allow read, write: if true;
    }

    // ── 서브컬렉션: items / templates / meta ─────────────────────────────────
    match /todos_db/{document}/{subpath=**} {
      allow read, write: if true;
    }

    // ── 백업 — 원본 단일 문서 롤백용 ─────────────────────────────────────────
    match /todos_db_backup/{document} {
      allow read, write: if true;
    }
  }
}
