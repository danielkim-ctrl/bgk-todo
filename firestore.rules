rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ 사용자 지시로 auth 없이 공개 접근 허용 상태 (2026-04-22)
    // PIN 로그인이 클라이언트 UI 보안을 담당하고, 인증 세팅은 추후 별도 진행 예정.

    // ── 단일 문서 todos_db/team — 쓰기 명시적 차단 ─────────────────────────
    // 2026-04-29: Phase 2-3 전환 후 legacy 코드의 stale write 사이클 끊기 위해.
    // 명시적 path로 작성 (이전 wildcard 패턴이 작동 안 한 이슈 대응).
    match /todos_db/team {
      allow read: if true;
      allow write: if false;
    }

    // ── 서브컬렉션 명시적 허용 — items / templates / meta / projects ─────────
    match /todos_db/team/items/{itemId} {
      allow read, write: if true;
    }
    match /todos_db/team/templates/{tplId} {
      allow read, write: if true;
    }
    match /todos_db/team/meta/{metaId} {
      allow read, write: if true;
    }
    match /todos_db/team/projects/{projId} {
      allow read, write: if true;
    }

    // ── 백업 — 원본 단일 문서 롤백용 ─────────────────────────────────────────
    match /todos_db_backup/{document} {
      allow read, write: if true;
    }
  }
}
